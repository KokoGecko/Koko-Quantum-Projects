   "source": [
    "import numpy as np\n",
    "import matplotlib.pyplot as plt"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "56a6f7d6-460f-497b-b43a-0b608e922725",
   "metadata": {},
   "outputs": [],
   "source": [
    "x = np.linspace(-10,10,1000)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "f3a4f6d8-6292-4655-8a0f-3d6ffe16e801",
   "metadata": {},
   "outputs": [],
   "source": [
    "sigma_x = 1.0\n",
    "k0 = 2.0\n",
    "A = 1 / (2 * np.pi * sigma_x**2)**0.25\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "d610240d-f488-4a30-97ec-522ad0270111",
   "metadata": {},
   "outputs": [],
   "source": [
    "psi = A * np.exp(-x**2 / (4 * sigma_x**2)) * np.exp(1j * k0 * x)\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "26ce97e4-b9aa-4169-919e-ea6fab051bd9",
   "metadata": {},
   "outputs": [],
   "source": [
    "rho = np.abs(psi)**2"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "b9338289-6292-44e2-86ba-8089486929bd",
   "metadata": {},
   "outputs": [],
   "source": [
    "psi_p = np.fft.fft(psi)\n",
    "p = np.fft.fftfreq(len(x), d=(x[1]-x[0])) * 2 * np.pi\n",
    "\n",
    "rho_p = np.abs(psi_p)**2\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 13,
   "id": "b2cdeeae-b8a6-414e-93ae-54215cbfe68e",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 640x480 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "psi_p_shift = np.fft.fftshift(psi_p)\n",
    "p_shift = np.fft.fftshift(p)\n",
    "rho_p = np.abs(psi_p_shift)**2\n",
    "\n",
    "plt.plot(p_shift, rho_p)\n",
    "plt.xlabel('p')\n",
    "plt.ylabel('|φ(p)|²')\n",
    "plt.title('Gaussian Wave Packet - Momentum Space')\n",
    "plt.xlim(-20, 20)\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "id": "8b13762b-331a-4107-9f5d-3225a8d1384e",
   "metadata": {},
   "outputs": [],
   "source": [
    "dx = x[1] - x[0]\n",
    "mean_x = np.sum(x * rho * dx)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 9,
   "id": "dbd7e86d-51b2-4a73-9543-39a3f351f0f7",
   "metadata": {},
   "outputs": [],
   "source": [
    "mean_x2 = np.sum(x**2 * rho * dx)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 10,
   "id": "58238986-3af8-48a2-a496-29b75b4000ab",
   "metadata": {},
   "outputs": [],
   "source": [
    "sigma_x_calc =np.sqrt(mean_x2 - mean_x**2)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 17,
   "id": "3d82ae1b-2a8d-4ed7-97c8-264a069e3525",
   "metadata": {},
   "outputs": [],
   "source": [
    "rho_p_norm = rho_p / np.sum(rho_p * dp)\n",
    "mean_p = np.sum(p_shift * rho_p_norm * dp)\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 20,
   "id": "913d702a-3b0b-428b-bd06-8f9507c3c1ea",
   "metadata": {},
   "outputs": [],
   "source": [
    "mean_p2 = np.sum(p_shift**2 * rho_p_norm * dp)\n",
    "sigma_p_calc = np.sqrt(mean_p2 - mean_p**2)"
   ]
  },
